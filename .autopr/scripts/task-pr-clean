#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

# shellcheck disable=SC1091
source "$ROOT/.autopr/scripts/common.sh"

source_branch="$(git rev-parse --abbrev-ref HEAD)"
if ! is_autopr_branch "$source_branch"; then
  echo "Current branch is not a codex task branch: $source_branch"
  exit 1
fi

if ! git diff --quiet || ! git diff --cached --quiet || [ -n "$(git ls-files --others --exclude-standard)" ]; then
  echo "[FAIL] Working tree has uncommitted changes on $source_branch."
  echo "       Commit task changes first, then rerun task:pr:clean."
  echo "       Suggested: ./scripts/committer \"<message>\" <files...>"
  exit 1
fi

diff_base_ref="$(resolve_base_ref "${DIFF_BASE_REF:-${BASE_REF:-origin/main}}")"
clean_base_ref="$(resolve_base_ref "${CLEAN_BASE_REF:-upstream/main}")"
base_commit="$(git rev-parse "$clean_base_ref")"

files=()
while IFS= read -r file; do
  [ -n "$file" ] || continue
  files+=("$file")
done < <(changed_files_against_base "$diff_base_ref")
if [ "${#files[@]}" -eq 0 ]; then
  echo "No changes found against $diff_base_ref"
  exit 1
fi

filtered=()
for f in "${files[@]}"; do
  if ! is_system_file "$f"; then
    filtered+=("$f")
  fi
done

if [ "${#filtered[@]}" -eq 0 ]; then
  echo "Only system automation files changed. Nothing to carry into clean PR branch."
  exit 1
fi

clean_branch="clean/${source_branch//\//-}"
if git show-ref --verify --quiet "refs/heads/$clean_branch"; then
  clean_branch="${clean_branch}-$(date +%Y%m%d%H%M%S)"
fi

git switch -c "$clean_branch" "$base_commit"
git checkout "$source_branch" -- "${filtered[@]}"

if git diff --cached --quiet && git diff --quiet; then
  echo "No effective content after filtering."
  exit 1
fi

git add -- "${filtered[@]}"

msg="${1:-AutoPR: clean branch from $source_branch}"
git commit -m "$msg"

# Final safety gate for upstream-targeted PRs.
upstream_ref="$(resolve_base_ref "upstream/main")"
system_files="$(find_system_files_in_diff "$upstream_ref" || true)"
if [ -n "$system_files" ]; then
  echo "[FAIL] Clean branch still contains system automation files vs $upstream_ref:"
  printf '%s\n' "$system_files" | sed 's/^/  - /'
  exit 1
fi

echo "Created clean branch: $clean_branch"
echo "Diff base for change capture: $diff_base_ref"
echo "Base for clean PR branch: $clean_base_ref"
echo "Filtered-in files:"
printf '%s\n' "${filtered[@]}" | sed 's/^/  - /'
echo "Next: git push -u <fork-remote> $clean_branch"
