#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

# shellcheck disable=SC1091
source "$ROOT/.autopr/scripts/common.sh"

usage() {
  cat <<USAGE
Usage:
  .autopr/scripts/task-start <task-id> [area]
USAGE
}

sanitize() {
  local v="$1"
  v="$(printf '%s' "$v" | tr '[:upper:]' '[:lower:]')"
  v="${v// /-}"
  v="${v//\//-}"
  printf '%s\n' "$v" | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//'
}

if [ "$#" -lt 1 ] || [ "$#" -gt 2 ]; then
  usage
  exit 2
fi

task_id="$(sanitize "$1")"
area="$(sanitize "${2:-core}")"
[ -n "$task_id" ] || { echo "task-id is empty after normalization"; exit 1; }

branch="codex/${area}/${task_id}"
worktree_dir=".worktrees/${branch//\//-}"
task_base_ref="$(resolve_base_ref "${TASK_BASE_REF:-origin/main}")"

# Keep both remotes fresh when available. Ignore missing remotes.
git fetch origin main >/dev/null 2>&1 || true
git fetch upstream main >/dev/null 2>&1 || true

if git show-ref --verify --quiet "refs/heads/$branch"; then
  echo "Local branch already exists: $branch"
  exit 1
fi

if [ -d "$worktree_dir" ]; then
  echo "Worktree already exists: $worktree_dir"
  echo "cd $worktree_dir"
  exit 0
fi

mkdir -p .worktrees
git worktree add "$worktree_dir" -b "$branch" "$task_base_ref"

if [ ! -f "$worktree_dir/.autopr/scripts/task-verify" ]; then
  echo "[FAIL] task harness missing in new worktree: $worktree_dir"
  echo "       expected: .autopr/scripts/task-verify"
  echo "       base ref: $task_base_ref"
  exit 1
fi

echo "Created task workspace:"
echo "  branch:   $branch"
echo "  worktree: $worktree_dir"
echo "  base:     $task_base_ref"
echo "Next:"
echo "  cd $worktree_dir"
echo "  .autopr/scripts/task-verify"
