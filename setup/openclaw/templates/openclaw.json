{
  "meta": {
    "lastTouchedVersion": "2026.3.3"
  },
  "models": {
    "mode": "merge",
    "providers": {
      "minimax": {
        "baseUrl": "https://api.minimaxi.com/anthropic",
        "apiKey": "@@MINIMAX_API_KEY@@",
        "api": "anthropic-messages",
        "authHeader": true,
        "models": [
          {
            "id": "MiniMax-M2.5",
            "name": "MiniMax-M2.5",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 204800,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "minimax/MiniMax-M2.5"
      },
      "workspace": "@@OPENCLAW_HOME@@/workspace",
      "heartbeat": {
        "every": "30m"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    },
    "list": [
      {
        "id": "scheduler",
        "default": true,
        "workspace": "@@OPENCLAW_HOME@@/workspace-scheduler",
        "tools": {
          "profile": "full",
          "exec": {
            "security": "full",
            "ask": "off"
          }
        }
      }
    ]
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "open",
      "botToken": "@@TELEGRAM_BOT_TOKEN@@",
      "allowFrom": ["*"],
      "groupPolicy": "allowlist",
      "streaming": "off"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "@@GATEWAY_TOKEN@@"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "bindings": [
    {
      "agentId": "scheduler",
      "match": {
        "channel": "telegram",
        "accountId": "*"
      }
    }
  ]
}
